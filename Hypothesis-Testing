    "# Observed frequencies\n",
    "observed = [\n",
    "    [30, 20],\n",
    "    [20, 30]\n",
    "]\n",
    "\n",
    "rows = len(observed)\n",
    "cols = len(observed[0])\n",
    "\n",
    "# -----------------------------\n",
    "# Step 1: Row totals\n",
    "# -----------------------------\n",
    "row_totals = []\n",
    "\n",
    "for row in observed:\n",
    "    row_totals.append(sum(row))\n",
    "\n",
    "print(\"Row Totals:\", row_totals)\n",
    "\n",
    "# -----------------------------\n",
    "# Step 2: Column totals\n",
    "# -----------------------------\n",
    "col_totals = []\n",
    "\n",
    "for j in range(cols):\n",
    "    total = 0\n",
    "    for i in range(rows):\n",
    "        total += observed[i][j]\n",
    "    col_totals.append(total)\n",
    "\n",
    "print(\"Column Totals:\", col_totals)\n",
    "\n",
    "# -----------------------------\n",
    "# Step 3: Grand total\n",
    "# -----------------------------\n",
    "grand_total = sum(row_totals)\n",
    "\n",
    "print(\"Grand Total:\", grand_total)\n",
    "\n",
    "# -----------------------------\n",
    "# Step 4: Expected frequencies\n",
    "# -----------------------------\n",
    "expected = []\n",
    "\n",
    "for i in range(rows):\n",
    "    row = []\n",
    "    for j in range(cols):\n",
    "        e = (row_totals[i] * col_totals[j]) / grand_total\n",
    "        row.append(e)\n",
    "    expected.append(row)\n",
    "\n",
    "print(\"\\nExpected Frequencies\")\n",
    "\n",
    "for row in expected:\n",
