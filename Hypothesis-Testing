   "source": [
    "# H0 -> mean = 50\n",
    "# H1 -> mean != 50\n",
    "\n",
    "pop_mean = 50\n",
    "sample_mean = 49.7\n",
    "sample_size = 25\n",
    "sample_std = 1.2\n",
    "\n",
    "t_value = (sample_mean - pop_mean)/(sample_std/math.sqrt(sample_size))\n",
    "print(t_value)"
   ]
