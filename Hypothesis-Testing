    "        E = expected[i][j]\n",
    "\n",
    "        contribution = ((O - E) ** 2) / E\n",
    "\n",
    "        chi_square += contribution\n",
    "\n",
    "        print(\n",
    "            f\"Observed={O}, Expected={E:.2f}, Contribution={contribution:.2f}\"\n",
    "        )\n",
    "\n",
